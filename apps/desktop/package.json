{
  "name": "westwavegem-desktop",
  "version": "0.1.0",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json --watch\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "electron": "electron .",
    "start": "npm run build && npm run electron",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "electron": "^29.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sockjs-client": "^1.6.1",
    "tmi.js": "^1.8.5",
    "ws": "^8.21.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.19.41",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sockjs-client": "^1.5.4",
    "@types/tmi.js": "^1.8.6",
    "@types/ws": "^8.18.1",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "tv.westwave.radio",
    "productName": "WestWaveGem Radio",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../data/music",
        "to": "data/music"
      },
      {
        "from": "../../kokoro-v1.0.onnx",
        "to": "kokoro-v1.0.onnx"
      },
      {
        "from": "../../voices",
        "to": "voices"
      }
    ],
    "directories": {
      "output": "../../release"
    }
  }
}
