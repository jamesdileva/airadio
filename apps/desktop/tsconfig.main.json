    "target":           "ES2020",
    "module":           "node16",
    "moduleResolution": "node16",
    "outDir":           "./dist",
    "rootDir":          "./src",
    "strict":           true,
    "skipLibCheck":     true,
    "esModuleInterop":  true,
  },
  "include": ["src/main", "src/shared"]
}